# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ─────────────────────────────────────────────────────────────────
# Required — app will throw on startup if missing.
MONGO_URI=mongodb://localhost:27017/comicstream

# Docker internal connection variables (used by docker-compose services)
# MONGO_ROOT_USER=admin
# MONGO_ROOT_PASS=change_me
# MONGO_URI_DOCKER=mongodb://admin:change_me@mongo:27017/comic_platform?authSource=admin
# REDIS_URL_DOCKER=redis://redis:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Required — use a strong random string (min 32 chars each).
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── File Upload ──────────────────────────────────────────────────────────────
# Local disk path for uploaded covers and chapter images.
# For production, point at a mounted object-storage volume.
UPLOAD_DIR=uploads

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000    # 15 minutes in milliseconds
RATE_LIMIT_MAX=100             # max requests per window per IP (global)

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── Redis Cache (optional) ───────────────────────────────────────────────────
# Leave blank to disable cache layer entirely (app runs fine without it).
# REDIS_URL=redis://localhost:6379

# ─── Queue-based Scraper Scheduler (optional) ─────────────────────────────────
# BullMQ scheduler/worker use Redis as transport.
# SCRAPER_SERIES_CRON=0 3 * * *
# SCRAPER_EPISODE_CRON=0 */6 * * *
# SCRAPER_FULL_EPISODE_CRON=0 1 * * 0
# SCRAPER_TZ=Asia/Jakarta
# SCRAPER_RUN_ON_STARTUP=true
# SCRAPER_DRY_RUN=false
# SCRAPER_JOB_TIMEOUT_MS=3600000
# SCRAPER_WORKER_CONCURRENCY=1

# ─── S3-Compatible Object Storage (optional) ──────────────────────────────────
# Leave all S3_* blank to use local disk upload (UPLOAD_DIR).
# Compatible with AWS S3, Cloudflare R2, MinIO, Backblaze B2, etc.
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key
# S3_BUCKET=comicstream-assets
# S3_REGION=auto
# S3_PUBLIC_URL=https://assets.yourdomain.com

# ─── Email / SMTP (optional) ──────────────────────────────────────────────────
# Leave SMTP_HOST blank to disable email entirely (forgot-password & email
# verification still work in terms of API responses, but no mail is sent).
# Compatible with any SMTP service: Gmail, Mailgun, SendGrid, Mailtrap, etc.
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_SECURE=false           # true for port 465 (TLS), false for STARTTLS
# SMTP_USER=postmaster@mg.yourdomain.com
# SMTP_PASS=your_smtp_password
# SMTP_FROM="ComicStream <noreply@yourdomain.com>"

# ─── Application URL ──────────────────────────────────────────────────────────
# Used to build password-reset and email-verification links in emails.
# APP_URL=https://yourdomain.com

# ─── Branding ─────────────────────────────────────────────────────────────────
# Name returned in API responses and health checks.
# APP_NAME=Audira Comic API
# SITE_CREATOR=Audira
