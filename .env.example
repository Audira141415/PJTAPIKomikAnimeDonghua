# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ─────────────────────────────────────────────────────────────────
# Required — app will throw on startup if missing.
MONGO_URI=mongodb://localhost:27017/comicstream

# Docker internal connection variables (used by docker-compose services)
# MONGO_ROOT_USER=admin
# MONGO_ROOT_PASS=change_me
# MONGO_URI_DOCKER=mongodb://admin:change_me@mongo:27017/comic_platform?authSource=admin
# REDIS_URL_DOCKER=redis://redis:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Required — use a strong random string (min 32 chars each).
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── File Upload ──────────────────────────────────────────────────────────────
# Local disk path for uploaded covers and chapter images.
# For production, point at a mounted object-storage volume.
UPLOAD_DIR=uploads

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000    # 15 minutes in milliseconds
RATE_LIMIT_MAX=100             # max requests per window per IP (global)

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
# TRUST_PROXY=true  # enable when running behind reverse proxy/load balancer

# ─── Redis Cache (optional) ───────────────────────────────────────────────────
# Leave blank to disable cache layer entirely (app runs fine without it).
# REDIS_URL=redis://localhost:6379

# ─── Queue-based Scraper Scheduler (optional) ─────────────────────────────────
# BullMQ scheduler/worker use Redis as transport.
# SCRAPER_SERIES_CRON=0 3 * * *
# SCRAPER_EPISODE_CRON=0 */6 * * *
# SCRAPER_FULL_EPISODE_CRON=0 1 * * 0
# SCRAPER_FULL_IMPORT_CRON=0 6 * * *
# SCRAPER_TZ=Asia/Jakarta
# SCRAPER_RUN_ON_STARTUP=true
# SCRAPER_DRY_RUN=false
# SCRAPER_JOB_TIMEOUT_MS=3600000
# SCRAPER_WORKER_CONCURRENCY=1
# FULL_IMPORT_DISABLED_STAGES=mangadex-all

# Endpoint monitor scheduler (optional) — sends Telegram alert for failing endpoints
# ENDPOINT_MONITOR_ENABLED=false
# ENDPOINT_MONITOR_CRON=*/15 * * * *
# ENDPOINT_MONITOR_BASE_URL=http://127.0.0.1:5000
# ENDPOINT_MONITOR_TIMEOUT_MS=10000
# ENDPOINT_MONITOR_NOTIFY_ON_SUCCESS=false
# ENDPOINT_MONITOR_MAX_FAIL_LINES=20
# ENDPOINT_MONITOR_MAX_TARGETS=50
# ENDPOINT_MONITOR_ALLOW_PRIVATE_BASE_URL=true
# Optional JSON array for custom checks:
# ENDPOINT_MONITOR_TARGETS=[{"method":"GET","path":"/health","expectedStatus":[200]},{"method":"GET","path":"/api/v1/mangas?limit=1","expectedStatus":[200]}]

# Telegram alert target (optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Client usage tracking (admin analytics for API consumers)
# CLIENT_USAGE_TRACKING_ENABLED=true
# CLIENT_API_KEY_SALT_ROUNDS=12

# ─── S3-Compatible Object Storage (optional) ──────────────────────────────────
# Leave all S3_* blank to use local disk upload (UPLOAD_DIR).
# Compatible with AWS S3, Cloudflare R2, MinIO, Backblaze B2, etc.
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key
# S3_BUCKET=comicstream-assets
# S3_REGION=auto
# S3_PUBLIC_URL=https://assets.yourdomain.com

# ─── Email / SMTP (optional) ──────────────────────────────────────────────────
# Leave SMTP_HOST blank to disable email entirely (forgot-password & email
# verification still work in terms of API responses, but no mail is sent).
# Compatible with any SMTP service: Gmail, Mailgun, SendGrid, Mailtrap, etc.
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_SECURE=false           # true for port 465 (TLS), false for STARTTLS
# SMTP_USER=postmaster@mg.yourdomain.com
# SMTP_PASS=your_smtp_password
# SMTP_FROM="ComicStream <noreply@yourdomain.com>"

# ─── Application URL ──────────────────────────────────────────────────────────
# Used to build password-reset and email-verification links in emails.
# APP_URL=https://yourdomain.com

# ─── Branding ─────────────────────────────────────────────────────────────────
# Name returned in API responses and health checks.
# APP_NAME=Audira Comic API
# SITE_CREATOR=Audira
# APP_VERSION=1.0.0

# ─── Logging Configuration ────────────────────────────────────────────────────
# DEBUG, INFO, WARN, ERROR
LOG_LEVEL=debug
ENABLE_FILE_LOGGING=false
LOG_DIR=logs

# ─── Error Tracking & Monitoring ──────────────────────────────────────────────
# Sentry (error tracking & performance monitoring)
# SENTRY_DSN=https://xxxxx@sentry.io/project-id

# Slack Error Notifications (optional)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# New Relic APM (optional)
# NEW_RELIC_ENABLED=false
# NEW_RELIC_LICENSE_KEY=
# NEW_RELIC_APP_NAME=audira-api

# ─── Security Configuration ───────────────────────────────────────────────────
# HTTPS redirect (production only)
ENABLE_HTTPS_REDIRECT=false
STRICT_SSL_VERIFY=false
HELMET_ENABLED=true

# Token blacklist (for logout functionality)
TOKEN_BLACKLIST_ENABLED=true

# ─── Session & Cookie ─────────────────────────────────────────────────────────
SESSION_SECRET=change_me_session_secret_min_32_chars
# SECURE_COOKIES=false   # true only on production HTTPS

# ─── Database Connection Pool ─────────────────────────────────────────────────
DATABASE_POOL_SIZE=10
DATABASE_POOL_TIMEOUT=10000

# ─── Cache TTL (Time To Live) – in seconds ────────────────────────────────────
# Development: shorter TTL for testing
# Production: longer TTL for performance
CACHE_TTL_MANGA=3600
CACHE_TTL_ANIME=3600
CACHE_TTL_SEARCH=1800
CACHE_TTL_USER=900

# ─── API Configuration ────────────────────────────────────────────────────────
# Request timeout (milliseconds)
REQUEST_TIMEOUT=30000
# Default page size for paginated endpoints
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ─── Backup & Recovery ────────────────────────────────────────────────────────
# BACKUP_ENABLED=false
# BACKUP_FREQUENCY=daily
# BACKUP_RETENTION_DAYS=30
# BACKUP_PATH=/app/backups

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Enable/disable features
FEATURE_MFA_ENABLED=false
FEATURE_SOCIAL_LOGIN_ENABLED=false
FEATURE_ADVANCED_SEARCH_ENABLED=true
FEATURE_RECOMMENDATION_ENGINE_ENABLED=false

# ─── Development Flags ────────────────────────────────────────────────────────
# Seed database with sample data on startup (dev only!)
SEED_ON_START=false
# Enable verbose request/response logging
DEBUG_REQUESTS=false
# Enable query performance timing
TIMING_ENABLED=false

# ─── External Services ────────────────────────────────────────────────────────
# Scraper configuration
SCRAPER_TIMEOUT=30000
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# ─── Payment Integration (optional) ────────────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=

# ─── AWS Services (optional) ──────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ─── Third-party APIs ─────────────────────────────────────────────────────────
# Add any required API keys here
# TMDB_API_KEY=           # TheMovieDB for additional metadata
# ANILIST_API_URL=        # AniList GraphQL endpoint

# ═════════════════════════════════════════════════════════════════════════════
# SETUP INSTRUCTIONS
# ═════════════════════════════════════════════════════════════════════════════
# 
# 1. Development Setup:
#    $ cp .env.example .env.local
#    $ # Edit .env.local with your local values
#    $ npm run dev
#
# 2. Docker Setup:
#    $ docker-compose up -d
#    $ # Containers use MONGO_URI_DOCKER and REDIS_URL_DOCKER
#
# 3. Production Setup:
#    - NEVER commit production .env files to git
#    - Use platform secret manager (Railway, Vercel, AWS Secrets Manager)
#    - Rotate secrets every 90 days
#
# 4. Generate Secure JWT Secrets:
#    $ node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# 5. Validate Environment:
#    $ npm run validate:env
#    $ # Checks all required variables are set and valid
#
# For detailed environment configuration guide, see: ENVIRONMENT_SETUP.md
# For security setup & hardening, see: SECURITY_AUDIT.md
# For production deployment, see: DEPLOYMENT_GUIDE.md
# ═════════════════════════════════════════════════════════════════════════════
