{
  "name": "audira-comic-api",
  "version": "1.0.0",
  "description": "Audira Comic API — Backend untuk platform komik, manhwa, manhua, anime, dan donghua milik Audira",
  "author": "Audira",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:up": "dev-local.bat",
    "dev:down": "dev-stop.bat docker",
    "dev:dockerdb": "set NODE_ENV=development&&set PORT=5000&&nodemon server.js",
    "seed": "node scripts/seed.js",
    "import:mangadex": "node scripts/mangadex-import.js",
    "import:mangadex:all": "node scripts/mangadex-import.js --all",
    "import:anichin": "node scripts/anichin-import.js",
    "seed:anime": "node scripts/anime-seed.js",
    "seed:anime:dryrun": "node scripts/anime-seed.js --dry-run",
    "sync:anime:proxy": "node scripts/anime-sync-proxy.js --update",
    "backfill:inference": "node scripts/backfill-inference-from-db.js",
    "backfill:inference:force": "node scripts/backfill-inference-from-db.js --force",
    "sync:anime:proxy:dryrun": "node scripts/anime-sync-proxy.js --dry-run",
    "sync:comic:sources": "node scripts/comic-sync-daily.js --sources all --page 1",
    "import:snapshots": "node scripts/import-snapshots-cli.js",
    "import:snapshots:dryrun": "node scripts/import-snapshots-cli.js --dry-run",
    "import:full": "node scripts/full-import.js",
    "scrape:anichin": "node scripts/anichin-scraper.js",
    "scrape:anichin:episodes": "node scripts/anichin-scraper.js --episodes",
    "seed:comic": "node scripts/comic-seed.js",
    "seed:comic:dryrun": "node scripts/comic-seed.js --dry-run",
    "scheduler": "node scripts/scheduler.js",
    "worker": "node src/jobs/worker.js",
    "worker:dev": "nodemon src/jobs/worker.js",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest tests/unit --runInBand --forceExit",
    "test:integration": "jest tests/integration --runInBand --forceExit",
    "test:coverage": "jest --runInBand --forceExit --coverage",
    "lint:syntax": "node -e \"require('module-alias/register'); require('dotenv').config(); require('./src/app'); console.log('App loads OK')\"",
    "security:audit": "npm audit --audit-level=high"
  },
  "keywords": [
    "manga",
    "manhwa",
    "manhua",
    "comic",
    "api"
  ],
  "license": "MIT",
  "dependencies": {
    "axios": "^1.14.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.58.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.3.4",
    "mongoose": "^8.8.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "playwright": "^1.55.1",
    "rate-limit-redis": "^4.3.1",
    "slugify": "^1.6.6",
    "ssh2": "^1.17.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.2.2"
  },
  "_moduleAliases": {
    "@core": "src/core",
    "@domains": "src/domains",
    "@infrastructure": "src/infrastructure",
    "@apps": "apps",
    "@shared": "src/core/utils",
    "@models": "src/core/database/modelRegistry",
    "@middlewares": "src/middlewares",
    "@repositories": "src/core/database/repositoryRegistry",
    "@auth": "src/domains/identity/Auth",
    "@scrapers": "src/infrastructure/scraper/services",
    "@catalogs": "src/domains/catalogs",
    "@identity": "src/domains/identity",
    "@interactions": "src/domains/interactions",
    "@metrics": "src/domains/metrics",
    "@source-manager": "src/domains/infrastructure/SourceManager"
  }
}
